<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="5dp"
    tools:context=".ListActivity">
    <TextView
        android:id="@+id/SelfOnlineText"
        android:visibility="gone"
        android:gravity="center"
        android:textColor="#ffffff"
        android:textSize="30sp"
        android:text="@string/centerControl"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:id="@+id/SelfOnline"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:paddingRight="50dp"
            android:gravity="right|center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <Button
                android:layout_marginRight="20dp"
                android:background="@drawable/blue_shape"
                android:textColor="#ffffff"
                android:id="@+id/settingIP"
                android:text="设置IP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Button
                android:background="@drawable/blue_shape"
                android:textColor="#ffffff"
                android:id="@+id/settingTab"
                android:text="设置面板"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/lastPage"
                android:src="@mipmap/lastpage"
                android:layout_width="30dp"
                android:layout_height="30dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_weight="0.6"
                android:id="@+id/rec"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <ImageView
                android:id="@+id/nextPage"
                android:src="@mipmap/nextpage"
                android:layout_width="30dp"
                android:layout_height="30dp"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/closeApp"
        android:src="@mipmap/out2"
        android:layout_gravity="right|top"
        android:layout_width="50dp"
        android:layout_height="50dp"/>

    <include layout="@layout/setting_ip_item"
        android:visibility="gone"
        android:clickable="true"
        android:id="@+id/setIP"/>
    <include
        layout="@layout/setting_list_item"
        android:visibility="gone"
        android:clickable="true"
        android:id="@+id/setTab"/>
</FrameLayout>